@page
@model TeknikServis.Web.Pages.Customers.CreateModel
@{
    ViewData["Title"] = "Yeni Müşteri Ekle";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="page-title">
            <i class="ti ti-user-plus me-2"></i> Yeni Müşteri Kaydı
        </h2>
    </div>
    <div class="col-auto ms-auto d-print-none">
        <a asp-page="/Customers/Index" class="btn btn-ghost-secondary">
            <i class="ti ti-arrow-left me-2"></i> Listeye Dön
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header bg-primary-lt">
        <h3 class="card-title">Müşteri Bilgileri</h3>
    </div>
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.FirstName" class="form-label required">Ad</label>
                    <input asp-for="Input.FirstName" class="form-control" placeholder="Müşterinin adı" />
                    <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.LastName" class="form-label required">Soyad</label>
                    <input asp-for="Input.LastName" class="form-control" placeholder="Müşterinin soyadı" />
                    <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.Email" class="form-label required">E-Posta Adresi</label>
                    <input asp-for="Input.Email" type="email" class="form-control" placeholder="ornek@mail.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.PhoneNumber" class="form-label required">Telefon Numarası</label>
                    <input asp-for="Input.PhoneNumber" class="form-control" placeholder="05XX XXX XX XX" />
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                </div>

                <div class="col-12"><hr /></div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Input.TaxNumber" class="form-label">TC Kimlik / Vergi Numarası</label>
                    <input asp-for="Input.TaxNumber" class="form-control" placeholder="11 haneli TC veya 10 haneli Vergi No" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Input.TaxOffice" class="form-label">Vergi Dairesi</label>
                    <input asp-for="Input.TaxOffice" class="form-control" placeholder="Kurumsal müşteriler için" />
                </div>
                <div class="col-12 mb-3">
                    <label asp-for="Input.Address" class="form-label">Açık Adres</label>
                    <textarea asp-for="Input.Address" class="form-control" rows="2" placeholder="Mahalle, Sokak, No, İlçe/İl"></textarea>
                </div>
                <div class="col-12 mb-3">
                    <label asp-for="Input.Notes" class="form-label">Özel Notlar</label>
                    <textarea asp-for="Input.Notes" class="form-control" rows="2" placeholder="Müşteriyle ilgili eklemek istediğiniz notlar..."></textarea>
                </div>
            </div>

            <div class="form-footer text-end mt-4 border-top pt-3">
                <a asp-page="/Customers/Index" class="btn btn-link link-secondary">İptal</a>
                <button type="submit" class="btn btn-primary">
                    <i class="ti ti-device-floppy me-2"></i> Müşteriyi Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}