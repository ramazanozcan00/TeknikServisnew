@page
@model TeknikServis.Web.Pages.Customers.CreateModel
@{
    ViewData["Title"] = "Yeni Müşteri Ekle";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="page-title">Yeni Müşteri Oluştur</h2>
    </div>
    <div class="col-auto ms-auto">
        <a asp-page="/Customers/Index" class="btn btn-ghost-secondary">
            <i class="ti ti-arrow-left me-2"></i> Listeye Dön
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <form method="post" class="card">
            <div class="card-header bg-primary-lt">
                <h3 class="card-title">Müşteri Detayları</h3>
            </div>

            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row row-cards">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Input.FirstName" class="form-label required">Adı</label>
                            <input asp-for="Input.FirstName" class="form-control" placeholder="Örn: Ahmet" />
                            <span asp-validation-for="Input.FirstName" class="invalid-feedback d-block"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Input.LastName" class="form-label required">Soyadı</label>
                            <input asp-for="Input.LastName" class="form-control" placeholder="Örn: Yılmaz" />
                            <span asp-validation-for="Input.LastName" class="invalid-feedback d-block"></span>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label required">E-Posta Adresi</label>
                            <div class="input-icon">
                                <span class="input-icon-addon">
                                    <i class="ti ti-mail"></i>
                                </span>
                                <input asp-for="Input.Email" type="email" class="form-control" placeholder="ornek@sirket.com" />
                            </div>
                            <span asp-validation-for="Input.Email" class="invalid-feedback d-block"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Input.PhoneNumber" class="form-label required">Telefon Numarası</label>
                            <div class="input-icon">
                                <span class="input-icon-addon">
                                    <i class="ti ti-phone"></i>
                                </span>
                                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="05XX XXX XX XX" />
                            </div>
                            <span asp-validation-for="Input.PhoneNumber" class="invalid-feedback d-block"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="Input.TaxNumber" class="form-label">Vergi / TC Kimlik No</label>
                            <input asp-for="Input.TaxNumber" class="form-control" placeholder="Opsiyonel" />
                            <span asp-validation-for="Input.TaxNumber" class="invalid-feedback d-block"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer text-end">
                <button type="submit" class="btn btn-primary">
                    <i class="ti ti-device-floppy me-2"></i> Kaydet ve Tamamla
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}