@page
@model TeknikServis.Web.Pages.Notifications.CreateModel
@{
    ViewData["Title"] = "Yeni Duyuru Yayınla";
}

<div class="row align-items-center mb-4">
    <div class="col"><h2 class="page-title"><i class="ti ti-bell-ringing me-2 text-warning"></i> Sistem Duyurusu Yayınla</h2></div>
</div>

<div class="card shadow-sm mx-auto" style="max-width: 600px;">
    <form method="post">
        <div class="card-body p-4">
            <div class="mb-3">
                <label class="form-label required">Duyuru Başlığı (Örn: v1.2 Güncellemesi)</label>
                <input asp-for="Input.Title" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label required">Mesaj İçeriği</label>
                <textarea asp-for="Input.Message" class="form-control" rows="4" required></textarea>
            </div>
            <div class="mb-4">
                <label class="form-label">Bildirim Rengi (Önem Derecesi)</label>
                <select asp-for="Input.Color" class="form-select">
                    <option value="bg-primary">Mavi (Genel Bilgi)</option>
                    <option value="bg-success">Yeşil (Yeni Özellik / Başarı)</option>
                    <option value="bg-warning">Sarı (Uyarı)</option>
                    <option value="bg-danger">Kırmızı (Acil / Kritik)</option>
                </select>
            </div>
        </div>
        <div class="card-footer text-end bg-light">
            <button type="submit" class="btn btn-warning"><i class="ti ti-send me-2"></i> Yayınla</button>
        </div>
    </form>
</div>