<!DOCTYPE html>
@using MediatR
@using TeknikServis.Application.Features.Notifications.Queries
@inject IMediator Mediator
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Teknik Servis Yönetimi</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta20/dist/css/tabler.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@2.44.0/tabler-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f6fa;
        }
    </style>
</head>
<body class="layout-fluid">

    @{
        var notificationsResult = await Mediator.Send(new GetLatestNotificationsQuery(5));
        var notifications = notificationsResult.IsSuccess && notificationsResult.Data != null
        ? notificationsResult.Data
        : new List<TeknikServis.Application.Features.Notifications.DTOs.NotificationDto>();
    }

    <div class="page">
        <header class="navbar navbar-expand-md navbar-light d-print-none">
            <div class="container-fluid">

                <h1 class="navbar-brand navbar-brand-autodark d-none-navbar-horizontal pe-0 pe-md-3">
                    <a href="/" class="text-decoration-none d-flex align-items-center gap-2">
                        <i class="ti ti-tool text-primary fs-2"></i>
                        Teknik<span class="text-primary">Servis</span>
                    </a>
                </h1>

                <div class="navbar-nav flex-row order-md-last">

                    <div class="nav-item dropdown d-none d-md-flex me-3">
                        <a href="#" class="nav-link px-0" data-bs-toggle="dropdown" tabindex="-1" aria-label="Bildirimleri Göster">
                            <i class="ti ti-bell fs-2"></i>
                            @if (notifications.Any())
                            {
                                <span class="badge bg-red badge-blink"></span>
                            }
                        </a>
                        <div class="dropdown-menu dropdown-menu-arrow dropdown-menu-end dropdown-menu-card" style="width: 350px;">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between">
                                    <h3 class="card-title m-0">Sistem Bildirimleri</h3>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-page="/Notifications/Create" class="text-primary small"><i class="ti ti-plus"></i> Yayınla</a>
                                    }
                                </div>
                                <div class="list-group list-group-flush list-group-hoverable">
                                    @foreach (var n in notifications)
                                    {
                                        <div class="list-group-item">
                                            <div class="row align-items-center">
                                                <div class="col-auto">
                                                    <span class="status-dot status-dot-animated @n.Color d-block"></span>
                                                </div>
                                                <div class="col text-truncate">
                                                    <a href="#" class="text-body d-block fw-bold fs-4">@n.Title</a>
                                                    <div class="d-block text-muted text-truncate mt-n1" title="@n.Message">@n.Message</div>
                                                </div>
                                                <div class="col-auto text-muted text-nowrap small mt-2">@n.CreatedAt.ToString("dd MMM HH:mm")</div>
                                            </div>
                                        </div>
                                    }
                                    @if (!notifications.Any())
                                    {
                                        <div class="list-group-item text-center text-muted py-4">Yeni bildirim yok.</div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link d-flex lh-1 text-reset p-0" data-bs-toggle="dropdown" aria-label="Kullanıcı Menüsü">
                            <span class="avatar avatar-sm bg-primary-lt">
                                <i class="ti ti-user"></i>
                            </span>
                            <div class="d-none d-xl-block ps-2">
                                <div>@User.Identity?.Name</div>
                                <div class="mt-1 small text-muted">Sistem Yöneticisi</div>
                            </div>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                            <form asp-page="/Auth/Logout" method="post">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="ti ti-logout me-2"></i> Çıkış Yap
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="collapse navbar-collapse" id="navbar-menu">
                    <div class="d-flex flex-column flex-md-row flex-fill align-items-stretch align-items-md-center">
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/WorkOrders/Index">
                                    <span class="nav-link-icon d-md-none d-lg-inline-block">
                                        <i class="ti ti-layout-kanban text-warning"></i>
                                    </span>
                                    <span class="nav-link-title">Atölye (İş Emirleri)</span>
                                </a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Employees/Index">
                                        <span class="nav-link-icon d-md-none d-lg-inline-block">
                                            <i class="ti ti-user-shield text-danger"></i>
                                        </span>
                                        <span class="nav-link-title">Çalışan Yönetimi</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Roles/Index">
                                        <span class="nav-link-icon d-md-none d-lg-inline-block">
                                            <i class="ti ti-shield-lock text-danger"></i>
                                        </span>
                                        <span class="nav-link-title">Rol & Yetki Yönetimi</span>
                                    </a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Customers/Index">
                                    <span class="nav-link-icon d-md-none d-lg-inline-block">
                                        <i class="ti ti-users text-primary"></i>
                                    </span>
                                    <span class="nav-link-title">Müşteriler</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/SpareParts/Index">
                                    <span class="nav-link-icon d-md-none d-lg-inline-block">
                                        <i class="ti ti-packages text-primary"></i>
                                    </span>
                                    <span class="nav-link-title">Depo ve Stok</span>
                                </a>
                            </li>
                            @if (User.IsInRole("Admin") || User.IsInRole("Sekreter"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-page="/Payments/Index">
                                        <span class="nav-link-icon d-md-none d-lg-inline-block">
                                            <i class="ti ti-cash-banknote text-success"></i>
                                        </span>
                                        <span class="nav-link-title">Kasa ve Finans</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </header>

        <div class="page-wrapper">
            <div class="page-body">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1055">
        @if (TempData["SuccessMessage"] != null)
        {
            <div id="successToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body fs-5">
                        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }

        @if (TempData["InfoMessage"] != null)
        {
            <div id="infoToast" class="toast align-items-center text-white bg-info border-0" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body fs-5">
                        <i class="fas fa-info-circle me-2"></i> @TempData["InfoMessage"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta20/dist/js/tabler.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Başarı mesajı varsa göster
            var successEl = document.getElementById('successToast');
            if (successEl) {
                new bootstrap.Toast(successEl, { delay: 4000 }).show();
            }

            // Bilgi mesajı varsa göster
            var infoEl = document.getElementById('infoToast');
            if (infoEl) {
                new bootstrap.Toast(infoEl, { delay: 4000 }).show();
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>