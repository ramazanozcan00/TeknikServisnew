@page
@model TeknikServis.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Yönetim Paneli";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <div class="page-pretitle text-primary fw-bold">KURUMSAL ÖZET</div>
        <h2 class="page-title">İşletme İstatistikleri</h2>
    </div>
</div>

<div class="row row-cards">
    <div class="col-sm-6 col-lg-3">
        <div class="card card-sm card-link-pop shadow-sm border-0 border-start border-primary border-3">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <span class="bg-primary-lt text-primary avatar avatar-md shadow-sm">
                            <i class="ti ti-users fs-2"></i>
                        </span>
                    </div>
                    <div class="col">
                        <div class="font-weight-medium text-muted">Kayıtlı Müşteri</div>
                        <div class="h1 mb-0 fw-bold">@Model.Stats.TotalCustomers</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card card-sm card-link-pop shadow-sm border-0 border-start border-info border-3">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <span class="bg-info-lt text-info avatar avatar-md shadow-sm">
                            <i class="ti ti-devices fs-2"></i>
                        </span>
                    </div>
                    <div class="col">
                        <div class="font-weight-medium text-muted">Kayıtlı Cihaz</div>
                        <div class="h1 mb-0 fw-bold">@Model.Stats.TotalDevices</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card card-sm card-link-pop shadow-sm border-0 border-start border-warning border-3">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <span class="bg-warning-lt text-warning avatar avatar-md shadow-sm">
                            <i class="ti ti-tool fs-2"></i>
                        </span>
                    </div>
                    <div class="col">
                        <div class="font-weight-medium text-muted">Aktif İş Emri</div>
                        <div class="h1 mb-0 fw-bold text-warning">@Model.Stats.ActiveWorkOrders</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card card-sm card-link-pop shadow-sm border-0 border-start border-success border-3">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <span class="bg-success-lt text-success avatar avatar-md shadow-sm">
                            <i class="ti ti-check fs-2"></i>
                        </span>
                    </div>
                    <div class="col">
                        <div class="font-weight-medium text-muted">Tamamlanan İş</div>
                        <div class="h1 mb-0 fw-bold text-success">@Model.Stats.CompletedWorkOrders</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 overflow-hidden">
            <div class="card-status-top bg-primary"></div>
            <div class="card-body text-center py-5">
                <div class="mb-3">
                    <span class="avatar avatar-xl bg-primary-lt text-primary shadow-sm border-0">
                        <i class="ti ti-rocket fs-huge"></i>
                    </span>
                </div>
                <h3 class="display-6 fw-bold">Sistem Aktif!</h3>
                <p class="text-muted fs-3">Tüm modüller sorunsuz çalışıyor. Yeni bir işlem başlatmak ister misiniz?</p>
                <div class="mt-4 d-flex justify-content-center gap-3">
                    <a asp-page="/WorkOrders/Index" class="btn btn-primary btn-lg shadow-sm">
                        <i class="ti ti-layout-kanban me-2"></i> Atölye Panosu
                    </a>
                    <a asp-page="/Customers/Create" class="btn btn-outline-primary btn-lg border-2">
                        <i class="ti ti-user-plus me-2"></i> Müşteri Ekle
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header">
                <h3 class="card-title fw-bold"><i class="ti ti-bolt me-2 text-warning"></i> Hızlı Erişim</h3>
            </div>
            <div class="list-group list-group-flush">
                <a asp-page="/SpareParts/Index" class="list-group-item list-group-item-action d-flex align-items-center">
                    <i class="ti ti-packages me-3 text-muted fs-2"></i> Stok Durumunu Kontrol Et
                </a>
                <a asp-page="/Payments/Index" class="list-group-item list-group-item-action d-flex align-items-center">
                    <i class="ti ti-cash me-3 text-muted fs-2"></i> Günlük Kasa Raporu
                </a>
                <a asp-page="/WorkOrders/Create" class="list-group-item list-group-item-action d-flex align-items-center">
                    <i class="ti ti-circle-plus me-3 text-muted fs-2"></i> Yeni İş Emri Oluştur
                </a>
            </div>
        </div>
    </div>
</div>