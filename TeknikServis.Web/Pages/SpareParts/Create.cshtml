@page
@model TeknikServis.Web.Pages.SpareParts.CreateModel
@{
    ViewData["Title"] = "Yeni Parça Ekle";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="page-title"><i class="ti ti-plus me-2"></i> Yeni Parça / Stok Ekle</h2>
    </div>
</div>

<div class="card shadow-sm mx-auto" style="max-width: 700px;">
    <form method="post">
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-8 mb-3">
                    <label class="form-label required">Parça Adı</label>
                    <input asp-for="Input.Name" class="form-control" placeholder="Örn: iPhone 13 Pro Batarya" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label required">Stok Kodu</label>
                    <input asp-for="Input.Code" class="form-control" placeholder="Örn: IPH13-BAT" required />
                </div>
            </div>

            <div class="row bg-light p-3 rounded mb-3 border">
                <div class="col-md-6 mb-3 mb-md-0">
                    <label class="form-label text-muted">Alış Fiyatı (Maliyet)</label>
                    <div class="input-group">
                        <span class="input-group-text">₺</span>
                        <input asp-for="Input.PurchasePrice" type="number" step="0.01" class="form-control" />
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold text-primary required">Satış Fiyatı</label>
                    <div class="input-group border-primary">
                        <span class="input-group-text bg-primary text-white">₺</span>
                        <input asp-for="Input.SalePrice" type="number" step="0.01" class="form-control text-primary fw-bold" required />
                    </div>
                    <small class="form-hint mt-1">İş emrine eklendiğinde müşteriye yansıyacak tutardır.</small>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label required">Başlangıç Stoğu</label>
                    <input asp-for="Input.InitialStock" type="number" class="form-control" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Kritik Stok Uyarı Seviyesi</label>
                    <input asp-for="Input.CriticalLevel" type="number" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label required">Birim</label>
                    <select asp-for="Input.Unit" class="form-select">
                        <option value="Adet">Adet</option>
                        <option value="Metre">Metre</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="card-footer text-end bg-light">
            <a asp-page="./Index" class="btn btn-link link-secondary">İptal</a>
            <button type="submit" class="btn btn-primary"><i class="ti ti-device-floppy me-2"></i> Kaydet</button>
        </div>
    </form>
</div>