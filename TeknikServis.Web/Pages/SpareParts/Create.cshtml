@page
@model TeknikServis.Web.Pages.SpareParts.CreateModel
@{
    ViewData["Title"] = "Stok Girişi";
}

<form method="post">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h3 class="card-title"><i class="ti ti-package-import me-2"></i>Yeni Stok & Seri No Girişi</h3>
        </div>
        <div class="card-body">
            <div class="row row-cards">
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Ürün Barkodu</label>
                    <input asp-for="Input.Barcode" class="form-control" id="barcodeInput" placeholder="Barkodu okutun..." autofocus />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Fatura No</label>
                    <input asp-for="Input.PurchaseInvoiceNo" class="form-control" placeholder="Alış faturası no..." />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Ürün Adı</label>
                    <input asp-for="Input.Name" class="form-control" placeholder="Ürün tanımı..." />
                </div>

                <div class="col-md-3 mb-3">
                    <label class="form-label">Alış Fiyatı</label>
                    <input asp-for="Input.PurchasePrice" class="form-control" type="number" step="0.01" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Satış Fiyatı</label>
                    <input asp-for="Input.SalePrice" class="form-control" type="number" step="0.01" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">Kritik Stok</label>
                    <input asp-for="Input.CriticalStockLevel" class="form-control" type="number" />
                </div>
            </div>

            <div class="mt-4 p-3 bg-light border rounded">
                <h4 class="text-primary mb-3"><i class="ti ti-list-numbers me-1"></i>Seri Numaraları</h4>
                <div id="serialList">
                    <div class="input-group mb-2 serial-row">
                        <span class="input-group-text bg-white">1</span>
                        <input type="text" name="Input.SerialNumbers" class="form-control serial-input" placeholder="Seri numarasını okutun ve Enter'a basın">
                        <button type="button" class="btn btn-outline-danger" onclick="removeSerial(this)"><i class="ti ti-trash"></i></button>
                    </div>
                </div>
                <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="addSerialRow()">
                    <i class="ti ti-plus me-1"></i>Yeni Satır Ekle
                </button>
            </div>
        </div>
        <div class="card-footer text-end">
            <a asp-page="./Index" class="btn btn-link">İptal</a>
            <button type="submit" class="btn btn-success btn-lg px-5">Stok Kaydını Tamamla</button>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        function addSerialRow() {
            const container = document.getElementById('serialList');
            const index = container.querySelectorAll('.serial-row').length + 1;
            const html = `
                <div class="input-group mb-2 serial-row">
                    <span class="input-group-text bg-white">${index}</span>
                    <input type="text" name="Input.SerialNumbers" class="form-control serial-input" placeholder="Seri no...">
                    <button type="button" class="btn btn-outline-danger" onclick="removeSerial(this)"><i class="ti ti-trash"></i></button>
                </div>`;
            container.insertAdjacentHTML('beforeend', html);
            const inputs = container.querySelectorAll('.serial-input');
            inputs[inputs.length - 1].focus();
        }

        function removeSerial(btn) {
            if (document.querySelectorAll('.serial-row').length > 1) {
                btn.closest('.serial-row').remove();
            }
        }

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' && e.target.classList.contains('serial-input')) {
                e.preventDefault();
                if (e.target.value.trim() !== "") {
                    addSerialRow();
                }
            }
        });
    </script>
}@page
