@page
@model TeknikServis.Web.Pages.Auth.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Sisteme Giriş - Teknik Servis Yönetimi</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta20/dist/css/tabler.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@2.44.0/tabler-icons.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            overflow: hidden;
        }

        /* Sağ taraftaki arkaplan resmi için */
        .bg-login-image {
            /* Teknik servis temalı profesyonel bir stok görsel */
            background-image: url('https://images.unsplash.com/photo-1581092160562-40aa08e78837?q=80&w=2070&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
        }

        /* Resmin üzerine gelen mavi kurumsal degrade filtre */
        .overlay {
            background: linear-gradient(135deg, rgba(32,107,196,0.85) 0%, rgba(20,54,101,0.95) 100%);
            height: 100%;
            width: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            padding: 4rem;
            text-align: center;
        }

        /* Form elemanlarının odaklanma (focus) renk ayarları */
        .form-control:focus {
            box-shadow: 0 0 0 0.25rem rgba(32, 107, 196, 0.25);
            border-color: #206bc4;
        }
    </style>
</head>
<body class="d-flex flex-column bg-white">
    <div class="row g-0 flex-fill vh-100">

        <div class="col-12 col-lg-5 col-xl-4 border-top-wide border-primary d-flex flex-column justify-content-center shadow-lg" style="z-index: 10;">
            <div class="container container-tight my-5 px-lg-5">

                <div class="text-center mb-5">
                    <a href="#" class="navbar-brand navbar-brand-autodark">
                        <i class="ti ti-tool text-primary bg-primary-lt p-3 rounded-circle mb-3" style="font-size: 2.5rem;"></i>
                    </a>
                    <h1 class="m-0 fw-bold fs-2">Teknik<span class="text-primary">Servis</span></h1>
                    <p class="text-muted mt-2">Kurumsal Yönetim Paneli</p>
                </div>

                <form method="post" class="mt-4">
                    <h2 class="h3 text-center mb-4">Hesabınıza Giriş Yapın</h2>

                    <div asp-validation-summary="ModelOnly" class="alert alert-important alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">E-Posta Adresi</label>
                        <div class="input-icon mb-3">
                            <span class="input-icon-addon">
                                <i class="ti ti-mail"></i>
                            </span>
                            <input asp-for="Input.Email" type="email" class="form-control form-control-lg" placeholder="admin@teknikservis.com" autocomplete="off" required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Şifre
                            <span class="form-label-description">
                                <a href="#" tabindex="-1">Şifremi Unuttum</a>
                            </span>
                        </label>
                        <div class="input-group input-group-flat">
                            <span class="input-group-text bg-transparent border-end-0">
                                <i class="ti ti-lock"></i>
                            </span>
                            <input asp-for="Input.Password" type="password" class="form-control form-control-lg border-start-0 ps-1" placeholder="Şifreniz" id="passwordInput" required autocomplete="off">
                            <span class="input-group-text bg-transparent">
                                <a href="#" class="link-secondary" title="Şifreyi Göster/Gizle" data-bs-toggle="tooltip" onclick="togglePassword(event)">
                                    <i class="ti ti-eye" id="eyeIcon"></i>
                                </a>
                            </span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-check">
                            <input type="checkbox" asp-for="Input.RememberMe" class="form-check-input" />
                            <span class="form-check-label">Beni bu bilgisayarda hatırla</span>
                        </label>
                    </div>

                    <div class="form-footer">
                        <button type="submit" class="btn btn-primary w-100 btn-lg rounded-3">
                            <i class="ti ti-login me-2"></i> Sisteme Giriş Yap
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-12 col-lg-7 col-xl-8 d-none d-lg-block">
            <div class="bg-login-image h-100">
                <div class="overlay">
                    <i class="ti ti-settings text-white opacity-50 mb-4" style="font-size: 5rem;"></i>
                    <h1 class="display-4 fw-bold mb-3">İşletmenizi Dijitalleştirin</h1>
                    <p class="fs-2 text-white-50 w-75">
                        Müşteri kayıtları, cihaz takibi ve atölye iş emirlerini tek bir noktadan, hızla ve güvenle yönetin.
                    </p>

                    <div class="mt-5 d-flex gap-4 opacity-75">
                        <div class="text-center">
                            <i class="ti ti-users fs-1 mb-2"></i>
                            <div class="fw-bold">Müşteri Yönetimi</div>
                        </div>
                        <div class="text-center">
                            <i class="ti ti-devices fs-1 mb-2"></i>
                            <div class="fw-bold">Cihaz Takibi</div>
                        </div>
                        <div class="text-center">
                            <i class="ti ti-layout-kanban fs-1 mb-2"></i>
                            <div class="fw-bold">Atölye Panosu</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script>
        function togglePassword(e) {
            e.preventDefault();
            var pwdInput = document.getElementById('passwordInput');
            var eyeIcon = document.getElementById('eyeIcon');

            if (pwdInput.type === 'password') {
                pwdInput.type = 'text';
                eyeIcon.classList.remove('ti-eye');
                eyeIcon.classList.add('ti-eye-off');
                eyeIcon.classList.add('text-primary'); // Açıkken mavi olsun
            } else {
                pwdInput.type = 'password';
                eyeIcon.classList.remove('ti-eye-off');
                eyeIcon.classList.remove('text-primary');
                eyeIcon.classList.add('ti-eye');
            }
        }
    </script>
</body>
</html>