@page
@model TeknikServis.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Sisteme Giriş";
    Layout = null; // Giriş sayfasında menülerin (Layout) olmaması gerekir
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Teknik Servis</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta20/dist/css/tabler.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@2.44.0/tabler-icons.min.css" />
    <style>
        body {
            background-color: #f4f6fa;
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="d-flex flex-column border-top-wide border-primary">
    <div class="page page-center">
        <div class="container container-tight py-4">

            <div class="text-center mb-4">
                <a href="#" class="navbar-brand navbar-brand-autodark">
                    <i class="ti ti-tool text-primary" style="font-size: 3rem;"></i>
                    <h1 class="m-0 mt-2">Teknik<span class="text-primary">Servis</span></h1>
                </a>
            </div>

            <div class="card card-md shadow-sm">
                <div class="card-body">
                    <h2 class="h2 text-center mb-4">Hesabınıza Giriş Yapın</h2>

                    <form method="post">

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger" role="alert">
                                <div class="d-flex">
                                    <div><i class="ti ti-alert-circle me-2"></i></div>
                                    <div asp-validation-summary="All" class="mb-0"></div>
                                </div>
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label required">E-Posta Adresi</label>
                            <input asp-for="Input.Email" type="email" class="form-control" placeholder="ornek@teknikservis.com" autocomplete="off" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label required">Şifre</label>
                            <div class="input-group input-group-flat">
                                <input asp-for="Input.Password" type="password" class="form-control" placeholder="Şifreniz" autocomplete="off" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-check cursor-pointer">
                                <input asp-for="Input.RememberMe" type="checkbox" class="form-check-input" />
                                <span class="form-check-label fw-medium user-select-none">Beni bu bilgisayarda hatırla</span>
                            </label>
                        </div>

                        <div class="form-footer">
                            <button type="submit" class="btn btn-primary w-100 py-2 fs-3">
                                <i class="ti ti-login me-2"></i> Giriş Yap
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center text-muted mt-3">
                Güvenli Kurumsal Giriş Ekranı &copy; @DateTime.Now.Year
            </div>

        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta20/dist/js/tabler.min.js"></script>
</body>
</html>