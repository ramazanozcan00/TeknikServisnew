@page "{id}"
@model TeknikServis.Web.Pages.Employees.EditModel
@{
    ViewData["Title"] = "Personel Düzenle";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="page-title"><i class="ti ti-user-edit me-2 text-primary"></i> Personel Bilgilerini Düzenle</h2>
    </div>
</div>

<div class="card shadow-sm mx-auto" style="max-width: 600px;">
    <form method="post">
        <input type="hidden" asp-for="Input.Id" />

        <div class="card-body p-4">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <div asp-validation-summary="All" class="text-danger mb-0"></div>
                </div>
            }

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label required">Ad</label>
                    <input asp-for="Input.FirstName" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label required">Soyad</label>
                    <input asp-for="Input.LastName" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label required">E-Posta Adresi (Giriş İçin Kullanılacak)</label>
                <input asp-for="Input.Email" type="email" class="form-control" />
            </div>

            <div class="mb-3 border border-warning rounded p-3 bg-warning-lt">
                <label class="form-label">Yeni Şifre Belirle <span class="text-muted fw-normal">(İsteğe Bağlı)</span></label>
                <input asp-for="Input.Password" type="text" class="form-control border-warning" placeholder="Şifreyi değiştirmek istemiyorsanız boş bırakın" />
                <small class="form-hint mt-2 text-warning"><i class="ti ti-alert-triangle me-1"></i> Eğer personelin mevcut şifresiyle devam etmesini istiyorsanız bu alanı kesinlikle boş bırakın.</small>
            </div>
            <div class="mb-4">
                <label class="form-label required">Sistem Yetkisi (Rol)</label>
                <select asp-for="Input.Role" class="form-select">
                    <option value="">-- Rol Seçiniz --</option>
                    @if (Model.AvailableRoles != null && Model.AvailableRoles.Any())
                    {
                        foreach (var role in Model.AvailableRoles)
                        {
                            <option value="@role">@role</option>
                        }
                    }
                </select>
            </div>

            <div class="mb-3 border p-3 rounded bg-light">
                <label class="form-check form-switch form-switch-lg cursor-pointer m-0">
                    <input class="form-check-input" type="checkbox" asp-for="Input.IsActive">
                    <span class="form-check-label fw-bold ms-2">
                        Personel Aktif Mi? (Sisteme Girebilir Mi?)
                    </span>
                </label>
                <small class="form-hint mt-2 ms-5">İşten ayrılan personeli silmek yerine pasife alınız. Pasif personeller sisteme giriş yapamaz.</small>
            </div>

        </div>
        <div class="card-footer text-end bg-light">
            <a asp-page="./Index" class="btn btn-link link-secondary">İptal</a>
            <button type="submit" class="btn btn-primary">
                <i class="ti ti-device-floppy me-2"></i> Değişiklikleri Kaydet
            </button>
        </div>
    </form>
</div>