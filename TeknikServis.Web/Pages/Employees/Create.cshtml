@page
@model TeknikServis.Web.Pages.Employees.CreateModel
@{
    ViewData["Title"] = "Yeni Çalışan Ekle";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="page-title"><i class="ti ti-user-plus me-2"></i> Yeni Personel Ekle</h2>
    </div>
</div>

<div class="card shadow-sm mx-auto" style="max-width: 600px;">
    <form method="post">
        <div class="card-body p-4">

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <div asp-validation-summary="All" class="text-danger mb-0"></div>
                </div>
            }

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label required">Ad</label>
                    <input asp-for="Input.FirstName" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label required">Soyad</label>
                    <input asp-for="Input.LastName" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label required">E-Posta Adresi (Giriş İçin Kullanılacak)</label>
                <input asp-for="Input.Email" type="email" class="form-control" placeholder="ornek@teknikservis.com" />
            </div>

            <div class="mb-3">
                <label class="form-label required">Sisteme Giriş Şifresi</label>
                <input asp-for="Input.Password" type="text" class="form-control" placeholder="En az 6 karakter" />
            </div>

            <div class="mb-4">
                <label class="form-label required">Sistem Yetkisi (Rol)</label>
                <select asp-for="Input.Role" class="form-select">
                    <option value="">-- Rol Seçiniz --</option>
                    @foreach (var role in Model.AvailableRoles)
                    {
                        <option value="@role">@role</option>
                    }
                </select>
                <small class="form-hint">Teknisyenler kasayı göremez. Sekreterler tahsilat yapabilir.</small>
            </div>

        </div>
        <div class="card-footer text-end bg-light">
            <a asp-page="./Index" class="btn btn-link link-secondary">İptal</a>
            <button type="submit" class="btn btn-primary">
                <i class="ti ti-device-floppy me-2"></i> Personeli Kaydet
            </button>
        </div>
    </form>
</div>