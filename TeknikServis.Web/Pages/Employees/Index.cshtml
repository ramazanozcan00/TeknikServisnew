@page
@model TeknikServis.Web.Pages.Employees.IndexModel
@{
    ViewData["Title"] = "Çalışan Yönetimi";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="page-title"><i class="ti ti-user-shield me-2"></i> Çalışan / Personel Yönetimi</h2>
    </div>
    <div class="col-auto ms-auto">
        <a asp-page="/Employees/Create" class="btn btn-primary">
            <i class="ti ti-user-plus me-1"></i> Yeni Çalışan Ekle
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table card-table table-vcenter text-nowrap">
            <thead>
                <tr>
                    <th>Ad Soyad</th>
                    <th>E-Posta Adresi</th>
                    <th>Yetkisi</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model.Employees)
                {
                    // (badgeClass vs aynı kalıyor)
                    <tr>
                        <td class="fw-bold fs-3">@emp.FullName</td>
                        <td class="text-muted">@emp.Email</td>
                        <td><span class="badge @@badgeClass fs-5">@emp.Role</span></td>

                        <td>
                            @if (emp.IsActive)
                            {
                                <span class="badge bg-success-lt text-success border-success">Aktif</span>
                            }
                            else
                            {

                                <span class="badge bg-danger-lt text-danger border-danger">Pasif</span>
                            }
                        </td>

                        <td class="text-end">
                            <a asp-page="./Edit" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-primary">
                                <i class="ti ti-edit me-1"></i> Düzenle
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>