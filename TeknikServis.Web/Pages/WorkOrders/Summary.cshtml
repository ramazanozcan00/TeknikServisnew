@page "{id:Guid}"
@model TeknikServis.Web.Pages.WorkOrders.SummaryModel
@using TeknikServis.Domain.Enums
@{
    ViewData["Title"] = "Servis Özeti ve Raporu";
}

<div class="row align-items-center mb-4 d-print-none">
    <div class="col">
        <h2 class="page-title"><i class="ti ti-file-certificate me-2"></i> İş Emri Servis Raporu</h2>
        <div class="text-muted mt-1">Kayıt No: <span class="fw-bold">@Model.Detail.WorkOrderNo</span></div>
    </div>
    <div class="col-auto ms-auto d-flex gap-2">
        <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modal-payment">
            <i class="ti ti-cash me-2"></i> Tahsilat Al
        </button>

        <button type="button" onclick="window.print();" class="btn btn-outline-primary">
            <i class="ti ti-printer me-2"></i> Raporu Yazdır
        </button>
        <button type="button" onclick="window.history.back();" class="btn btn-ghost-secondary">
            <i class="ti ti-arrow-left me-2"></i> Geri Dön
        </button>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible d-print-none" role="alert">
        <div class="d-flex">
            <div><i class="ti ti-check me-2" style="font-size:1.5rem;"></i></div>
            <div class="fw-bold">@TempData["SuccessMessage"]</div>
        </div>
        <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
    </div>
}

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
        <h3 class="card-title m-0 fs-3">Servis Detayları</h3>
        @{
            string badgeClass = Model.Detail.Status switch
            {
                WorkOrderStatus.Bekliyor => "bg-danger text-white",
                WorkOrderStatus.Onarimda => "bg-warning text-dark",
                WorkOrderStatus.Tamamlandi => "bg-success text-white",
                WorkOrderStatus.TeslimEdildi => "bg-info text-white",
                WorkOrderStatus.IptalEdildi => "bg-light text-dark",
                _ => "bg-primary text-white"
            };
        }
        <span class="badge @badgeClass text-uppercase px-3 py-2 fs-5 shadow-sm" style="letter-spacing: 1px; border-radius: 8px;">
            @Model.Detail.Status
        </span>
    </div>
    <div class="card-body">
        <div class="row mb-4">
            <div class="col-sm-6 mb-3 mb-sm-0">
                <h6 class="text-muted mb-2">MÜŞTERİ BİLGİLERİ</h6>
                <div class="fs-3 fw-bold text-primary">@Model.Detail.CustomerFullName</div>
                <div><i class="ti ti-phone me-1 text-muted"></i> @Model.Detail.CustomerPhone</div>
            </div>
            <div class="col-sm-6 text-sm-end">
                <h6 class="text-muted mb-2">CİHAZ BİLGİLERİ</h6>
                <div class="fs-3 fw-bold">@Model.Detail.DeviceBrand @Model.Detail.DeviceModel</div>
                <div class="text-muted">Seri No: @Model.Detail.DeviceSerial</div>
                <div class="text-muted">Açılış Tarihi: @Model.Detail.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
            </div>
        </div>

        <hr />

        <div class="mb-4">
            <h6 class="text-muted mb-2"><i class="ti ti-alert-triangle text-danger me-1"></i> MÜŞTERİ ŞİKAYETİ</h6>
            <div class="fs-4 bg-red-lt p-3 rounded border border-danger-subtle">@Model.Detail.Description</div>
        </div>

        <div class="mb-4">
            <h6 class="text-muted mb-2"><i class="ti ti-tool text-primary me-1"></i> TEKNİSYEN RAPORU VE YAPILAN İŞLEMLER</h6>
            <div class="fs-4 bg-primary-lt p-3 rounded border border-primary-subtle" style="white-space: pre-wrap; min-height: 100px;">@(string.IsNullOrWhiteSpace(Model.Detail.TechnicianNotes) ? "Henüz bir işlem yapılmamış veya not girilmemiş." : Model.Detail.TechnicianNotes)</div>
        </div>

        <hr />

        <div class="row align-items-center mt-4">
            <div class="col">
                <div class="text-uppercase text-muted fw-bold">Toplam Servis TutarI</div>
            </div>
            <div class="col-auto">
                <div class="display-6 fw-bold text-success">
                    @(Model.Detail.TotalPrice?.ToString("C2") ?? "0,00 ₺")
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal modal-blur fade d-print-none" id="modal-payment" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content border-success border-3 border-top">
            <div class="modal-header bg-success-lt">
                <h5 class="modal-title"><i class="ti ti-cash me-2 text-success"></i> Müşteriden Tahsilat Al</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="ReceivePayment">
                <div class="modal-body">
                    <input type="hidden" asp-for="PaymentInput.WorkOrderId" />
                    <input type="hidden" asp-for="PaymentInput.CustomerId" />

                    <div class="mb-3">
                        <label class="form-label fw-bold required">Tahsil Edilecek Tutar</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-success fw-bold fs-3">₺</span>
                            <input asp-for="PaymentInput.Amount" type="number" step="0.01" class="form-control text-success fw-bold fs-2" required />
                        </div>
                        <small class="form-hint">Sistem, iş emri tutarını otomatik getirdi. İsterseniz değiştirebilirsiniz.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold required">Ödeme Yöntemi</label>
                        <select asp-for="PaymentInput.Method" class="form-select form-select-lg">
                            <option value="@PaymentMethod.Nakit">💵 Nakit</option>
                            <option value="@PaymentMethod.KrediKarti">💳 Kredi Kartı / POS</option>
                            <option value="@PaymentMethod.HavaleEft">🏦 Havale / EFT</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Açıklama (Opsiyonel)</label>
                        <textarea asp-for="PaymentInput.Description" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-link link-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="ti ti-check me-2"></i> Kasaya Ekle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>