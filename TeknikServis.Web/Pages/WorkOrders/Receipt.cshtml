@page "{id:Guid}"
@model TeknikServis.Web.Pages.WorkOrders.ReceiptModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Servis Fişi - @Model.ReceiptData.WorkOrderNo</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/core@1.0.0-beta20/dist/css/tabler.min.css">
    <style>
        body {
            background-color: #fff;
            color: #000;
            font-family: 'Inter', sans-serif;
        }

        .receipt-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 40px;
            border: 1px solid #ddd;
            border-radius: 8px;
            margin-top: 20px;
        }
        /* Sadece yazdırırken çalışacak CSS */
        @@media print {
            .d-print-none {
                display: none !important;
            }

            .receipt-container {
                border: none;
                margin-top: 0;
                padding: 0;
            }
        }
    </style>
</head>
<body>
    <div class="receipt-container">
        <div class="row mb-4 align-items-center">
            <div class="col-8">
                <h1 class="mb-0">TEKNİK SERVİS TESLİM FİŞİ</h1>
                <div class="text-muted">Güvenilir Onarım Merkezi</div>
            </div>
            <div class="col-4 text-end">
                <h3 class="mb-0">Fiş No: @Model.ReceiptData.WorkOrderNo</h3>
                <div class="text-muted">Tarih: @Model.ReceiptData.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
            </div>
        </div>

        <hr />

        <div class="row mb-4 mt-4">
            <div class="col-6">
                <h4 class="text-uppercase border-bottom pb-2">Müşteri Bilgileri</h4>
                <strong>@Model.ReceiptData.CustomerName</strong><br />
                Telefon: @Model.ReceiptData.PhoneNumber
            </div>
            <div class="col-6 text-end">
                <h4 class="text-uppercase border-bottom pb-2">Cihaz Bilgileri</h4>
                <strong>@Model.ReceiptData.DeviceInfo</strong><br />
                Seri No: @Model.ReceiptData.SerialNumber
            </div>
        </div>

        <div class="mb-4">
            <h4 class="text-uppercase border-bottom pb-2">Müşteri Şikayeti / Arıza Özeti</h4>
            <p class="fs-4 p-3 bg-light rounded border">
                @Model.ReceiptData.Description
            </p>
        </div>

        <div class="row mt-5 pt-5 text-center">
            <div class="col-6">
                <strong>Teslim Eden (Müşteri)</strong><br />
                <br /><br />
                ..........................................
            </div>
            <div class="col-6">
                <strong>Teslim Alan (Servis)</strong><br />
                <br /><br />
                ..........................................
            </div>
        </div>

        <div class="text-center mt-5 d-print-none">
            <button class="btn btn-primary btn-lg" onclick="window.print()">
                <i class="ti ti-printer me-2"></i> Çıktı Al / PDF Kaydet
            </button>
            <a href="javascript:history.back()" class="btn btn-link">Geri Dön</a>
        </div>
    </div>
</body>
</html>