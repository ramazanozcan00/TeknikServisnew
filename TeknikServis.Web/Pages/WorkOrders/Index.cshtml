@page
@model TeknikServis.Web.Pages.WorkOrders.IndexModel
@using TeknikServis.Domain.Enums
@{
    ViewData["Title"] = "Atölye Panosu";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="page-title text-dark fw-bold">
            <span class="avatar bg-dark text-white me-2"><i class="ti ti-layout-kanban"></i></span>
            Atölye Canlı Takip
        </h2>
    </div>
    <div class="col-auto">
        <a asp-page="/WorkOrders/Create" class="btn btn-primary shadow-sm">
            <i class="ti ti-plus me-2"></i> Yeni İş Emri
        </a>
    </div>
</div>

<div class="row row-deck row-cards">

    <div class="col-md-4">
        <div class="card bg-light border-0 shadow-none">
            <div class="card-header bg-danger-lt border-bottom border-danger-subtle py-3 d-flex justify-content-between">
                <h3 class="card-title fw-bold text-danger"><i class="ti ti-clock-pause me-2"></i> SIRADAKİLER</h3>
                <span class="badge bg-danger text-white rounded-pill">
                    @Model.WorkOrders.Count(x => x.Status == WorkOrderStatus.Bekliyor)
                </span>
            </div>
            <div class="card-body p-2 kanban-col" style="min-height:75vh;">
                @foreach (var wo in Model.WorkOrders.Where(x => x.Status == WorkOrderStatus.Bekliyor))
                {
                    <div class="card mb-3 shadow-sm border-0 border-start border-danger border-3 card-link">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge badge-outline text-secondary fw-normal">#@wo.WorkOrderNo</span>
                                <span class="status-dot status-dot-animated bg-danger"></span>
                            </div>
                            <h4 class="mb-1 fw-bold text-dark">@wo.CustomerFullName</h4>
                            <div class="text-muted small mb-3">
                                <i class="ti ti-device-mobile me-1 text-primary"></i> @wo.DeviceInfo
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-page="/WorkOrders/Details" asp-route-id="@wo.Id" class="btn btn-sm btn-white w-100 shadow-none border-1">
                                    <i class="ti ti-eye me-1"></i> İncele
                                </a>
                                <form method="post" asp-page-handler="ChangeStatus" class="w-100">
                                    <input type="hidden" name="id" value="@wo.Id" />
                                    <input type="hidden" name="status" value="@(WorkOrderStatus.Onarimda)" />
                                    <button type="submit" class="btn btn-sm btn-danger w-100 shadow-sm">
                                        İşleme Al <i class="ti ti-chevron-right ms-1"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-light border-0 shadow-none">
            <div class="card-header bg-warning-lt border-bottom border-warning-subtle py-3 d-flex justify-content-between">
                <h3 class="card-title fw-bold text-warning"><i class="ti ti-settings-automation me-2"></i> MASADAKİLER</h3>
                <span class="badge bg-warning text-white rounded-pill">
                    @Model.WorkOrders.Count(x => x.Status == WorkOrderStatus.Onarimda)
                </span>
            </div>
            <div class="card-body p-2 kanban-col" style="min-height:75vh;">
                @foreach (var wo in Model.WorkOrders.Where(x => x.Status == WorkOrderStatus.Onarimda))
                {
                    <div class="card mb-3 shadow-sm border-0 border-start border-warning border-3 card-link">
                        <div class="card-body p-3 text-center">
                            <div class="d-flex justify-content-between align-items-start mb-2 text-start">
                                <span class="badge badge-outline text-warning">#@wo.WorkOrderNo</span>
                                <span class="status-dot status-dot-animated bg-warning"></span>
                            </div>
                            <div class="avatar avatar-md bg-warning-lt mb-2 rounded-circle">@wo.CustomerFullName.Substring(0, 1)</div>
                            <h4 class="mb-1 fw-bold">@wo.CustomerFullName</h4>
                            <p class="text-muted small">@wo.DeviceInfo</p>
                            <div class="progress progress-sm mb-3">
                                <div class="progress-bar progress-bar-indeterminate bg-warning"></div>
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-page="/WorkOrders/Details" asp-route-id="@wo.Id" class="btn btn-sm btn-white w-100 shadow-none border-1">Detaylar</a>
                                <form method="post" asp-page-handler="ChangeStatus" class="w-100">
                                    <input type="hidden" name="id" value="@wo.Id" />
                                    <input type="hidden" name="status" value="@(WorkOrderStatus.Tamamlandi)" />
                                    <button type="submit" class="btn btn-sm btn-warning w-100 shadow-sm">Bitir</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-light border-0 shadow-none">
            <div class="card-header bg-success-lt border-bottom border-success-subtle py-3 d-flex justify-content-between">
                <h3 class="card-title fw-bold text-success"><i class="ti ti-circle-check me-2"></i> BİTENLER</h3>
                <span class="badge bg-success text-white rounded-pill">
                    @Model.WorkOrders.Count(x => x.Status == WorkOrderStatus.Tamamlandi)
                </span>
            </div>
            <div class="card-body p-2 kanban-col" style="min-height:75vh;">
                @foreach (var wo in Model.WorkOrders.Where(x => x.Status == WorkOrderStatus.Tamamlandi))
                {
                    <div class="card mb-3 shadow-sm border-0 border-start border-success border-3 card-link">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="badge bg-success-lt text-success">HAZIR</span>
                                <small class="text-muted">#@wo.WorkOrderNo</small>
                            </div>
                            <h4 class="mb-1 fw-bold">@wo.CustomerFullName</h4>
                            <div class="text-muted small mb-3">@wo.DeviceInfo</div>
                            <button class="btn btn-success w-100 shadow-sm">
                                <i class="ti ti-truck-delivery me-2"></i> Müşteriye Teslim Et
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

</div>