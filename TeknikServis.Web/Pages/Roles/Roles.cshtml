@page
@model TeknikServis.Web.Pages.Roles.IndexModel
@{
    ViewData["Title"] = "Rol ve Yetki Yönetimi";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="page-title"><i class="ti ti-shield-lock me-2 text-danger"></i> Rol ve Yetki Yönetimi</h2>
    </div>
</div>

<div class="card shadow-sm mx-auto" style="max-width: 800px;">
    <div class="table-responsive">
        <table class="table card-table table-vcenter">
            <thead>
                <tr>
                    <th>Sistem Rolü</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var role in Model.Roles)
                {
                    <tr>
                        <td class="fw-bold fs-3">
                            <i class="ti ti-users text-muted me-2"></i> @role.Name
                        </td>
                        <td class="text-end">
                            <a asp-page="/Roles/Manage" asp-route-id="@role.Id" class="btn btn-primary btn-sm">
                                <i class="ti ti-settings me-1"></i> Yetkileri Düzenle
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>